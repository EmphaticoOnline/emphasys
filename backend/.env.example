# Puesto para desarrollo; ajusta según tu entorno
PORT=7001

# ==============================
# POSTGRESQL
# ==============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emphasys
DB_USER=postgres
DB_PASSWORD=postgres

# ==============================
# AUTH (JWT)
# ==============================
JWT_SECRET=emphasys_super_secret
JWT_EXPIRES_IN=12h



# ==============================
# FACTURAMA (SANDBOX)
# ==============================
FACTURAMA_BASE_URL=https://apisandbox.facturama.mx
FACTURAMA_USER=
FACTURAMA_PASSWORD=
FACTURAMA_STAMP_PATH=/cfdi40/stamp

# ==============================
# DESCARGA MASIVA DE CFDI DEL SAT
# ==============================
# Storage privado (fuera de uploads/, nunca servido por express.static) donde se
# guardan los ZIP y XML descargados del SAT. Opcional: si no se define, usa
# <cwd>/private-storage/cfdi-sat.
CFDI_SAT_STORAGE_DIR=

# ==============================
# NOTIFICACIONES PUSH (Web Push / VAPID)
# ==============================
# Par de claves VAPID del servidor, generado UNA SOLA VEZ (nunca en cada
# arranque del proceso) y fijo mientras existan suscripciones activas:
# cambiarlas invalida todas las suscripciones ya registradas por los
# navegadores. Ver el reporte del bloque de cimientos de push para las
# instrucciones exactas de generación. Nunca subas las claves reales de
# producción a este archivo de ejemplo ni al repositorio.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@emphasys.mx
