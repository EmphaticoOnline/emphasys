{
  "$schema": "https://json.schemastore.org/package",
  "name": "emphasys",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "bash ./deploy.sh",
    "deploy:backend:fast": "SKIP_FRONTEND=true SKIP_LOCAL_INSTALL=true SKIP_REMOTE_INSTALL=true bash ./deploy.sh",
    "deploy:win": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1",
    "deploy:test": "bash ./deploy-test.sh",
    "backend:build": "cd backend && npm run build",
    "backend:start": "cd backend && npm start",
    "frontend:build": "cd frontend && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run backend:build && npm run backend:start\" \"wait-on tcp:7001 && npm run frontend:dev\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.2.0",
    "concurrently": "^9.2.1",
    "wait-on": "^7.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.1"
  }
}
